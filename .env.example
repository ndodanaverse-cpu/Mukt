# Example .env for Mukoto Ave server
# Option A: point to a service account JSON file on disk (recommended for local testing)
FIRESTORE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B: set the full service account JSON as a single environment variable (CI/CD)
# FIRESTORE_SERVICE_ACCOUNT='{"type":"service_account", ... }'

# Optional: change port
# PORT=3000
